# Copy this file to .env before running the FastAPI demo.

# Model for the FastAPI / Streamlit demo. HF_MODEL_ID accepts EITHER a
# Hugging Face repo id OR a LOCAL path to a fine-tuned checkpoint.
#
# Run locally (no Hugging Face) — point at the folder saved by the notebook:
HF_MODEL_ID=models/vit5-news-v2
# Or pin a specific epoch checkpoint, e.g.:
# HF_MODEL_ID=models/vit5-news-v2/checkpoint-309
#
# Or load from the Hugging Face Hub instead:
# HF_MODEL_ID=your-hf-username/vit5-news-v2
#
# Base model used when HF_MODEL_ID is a LoRA adapter (the usual case here).
HF_BASE_MODEL_ID=VietAI/vit5-base
# Only needed for private/gated Hugging Face repos; leave blank for local paths.
HF_TOKEN=
# cpu, cuda, cuda:0, mps ... leave blank to keep the model on CPU.
MODEL_DEVICE=

# Web demo: crawl this many successfully extracted articles per request.
MAX_ARTICLES_PER_DEMO=5

# AI Studio labeling (free). Comma-separated keys rotated round-robin.
# Provide AS MANY keys as you have — every key is used, not just the first 3.
# Get keys at https://aistudio.google.com/apikey
# Default model: gemini-3.1-flash-lite (15 RPM, 500 RPD/project)
GEMINI_API_KEYS=key1,key2,key3,key4,key5
# Or a single key:
# GEMINI_API_KEY=your-single-key

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
