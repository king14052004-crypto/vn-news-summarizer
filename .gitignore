# Data — local artefacts, never commit
/data/raw/*
/data/interim/
/data/processed/
/data/external/
/data/datasets/*
/data/labeled/*
/data/app.db
/data/*.sqlite
/data/*.sqlite3
!/data/.gitkeep
!/data/raw/.gitkeep
!/data/datasets/.gitkeep
!/data/labeled/.gitkeep
# The curated v2 dataset is the training input and is committed with the repo.
!/data/datasets/v2/
!/data/datasets/v2/*.jsonl

# Models / artifacts — large checkpoints stay local, keep the folder in git.
/models/*
!/models/.gitkeep
