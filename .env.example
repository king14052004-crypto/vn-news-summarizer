# Copy this file to .env before running the FastAPI demo.

# Hugging Face model or LoRA adapter that matches the historical
# models/vit5-news-v2/checkpoint-309 result.
HF_MODEL_ID=your-hf-username/vit5-news-v2
HF_BASE_MODEL_ID=VietAI/vit5-base
HF_TOKEN=
MODEL_DEVICE=

# Web demo: crawl this many successfully extracted articles per request.
MAX_ARTICLES_PER_DEMO=5

# AI Studio labeling (default, free). Comma-separated keys for rotation.
# Get keys at https://aistudio.google.com/apikey
GEMINI_API_KEYS=key1,key2,key3
# Or a single key:
# GEMINI_API_KEY=your-single-key

# Vertex AI labeling (alternative, paid). Use --backend vertex.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./secrets/vertex-sa.json

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
